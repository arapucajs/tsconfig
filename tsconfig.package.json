{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "removeComments": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./build",
    "rootDir": "./src",
    "types": ["bun-types", "node", "@types/node"],
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "build", "dist", "test", "tests"]
}
